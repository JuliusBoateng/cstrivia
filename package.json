{
  "name": "cstrivia",
  "version": "1.0.0",
  "description": "Repo for https://cstrivia.com",
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "watch": "esbuild client/src/main.ts --bundle --sourcemap --outfile=crossword/static/crossword/dist/main.js --watch",
    "build": "esbuild client/src/main.ts --bundle --minify --outfile=crossword/static/crossword/dist/main.js",
    "format": "prettier --write \"client/src/**/*.ts\" && djlint crossword/templates --reformat && prettier --write crossword/static",
    "lint": "eslint \"client/src/**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JuliusBoateng/cstrivia.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/JuliusBoateng/cstrivia/issues"
  },
  "homepage": "https://github.com/JuliusBoateng/cstrivia#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  }
}
